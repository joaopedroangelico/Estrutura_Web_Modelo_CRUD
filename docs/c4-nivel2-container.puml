@startuml Nivel2
title C4 - Nível 2 (Contêineres) | Sistema de Oficina Mecânica

skinparam rectangle {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}

skinparam database {
  BackgroundColor #FFFDE7
  BorderColor #F9A825
}

skinparam actor {
  BackgroundColor #E3F2FD
  BorderColor #1E88E5
}

actor "Usuário Público" as Publico
actor "Funcionário / Admin" as Usuario

rectangle "Frontend Web\n(React + Vite + Tailwind)" as Frontend {
  note right
    Interface responsiva
    Homepage pública
    Login e CRUD
  end note
}

rectangle "Backend API\n(Node.js + Express)" as Backend {
  note right
    API REST
    JWT + Roles
    Regras de negócio
  end note
}

database "MongoDB" as DB {
  note right
    Usuários
    Funcionários
    Veículos
  end note
}

Publico --> Frontend : Acessa homepage
Usuario --> Frontend : Usa sistema autenticado
Frontend --> Backend : HTTP / JSON
Backend --> DB : CRUD / Persistência

@enduml